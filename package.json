{
  "name": "vsx",
  "version": "0.3.11",
  "module": "src/main.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "vsx": "src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun --watch run src/main.tsx",
    "test": "bun test",
    "test:ci-parity": "bun run scripts/ci-parity.ts",
    "build:release": "bun run scripts/build-release.ts",
    "typecheck": "tsc --noEmit",
    "release": "release-it --ci"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "release-it": "^19.2.4",
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "0.4.2",
    "@opentui/keymap": "0.4.2",
    "@opentui/react": "0.4.2",
    "diff": "9.0.0",
    "react": "19.2.7",
    "web-tree-sitter": "0.25.10"
  }
}
